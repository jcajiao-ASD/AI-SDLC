---
import BaseLayout from '../../layouts/BaseLayout.astro';
import StoryHero from '../../components/StoryHero.astro';
import ExecutiveSummary from '../../components/ExecutiveSummary.astro';
import Caveat from '../../components/Caveat.astro';
import EvidencePanel from '../../components/EvidencePanel.astro';
import DataTable from '../../components/DataTable.astro';
import BarChart from '../../components/BarChart';
import SensitivityExplorer from '../../components/SensitivityExplorer';
import { findDataset, findStudy, loadStudies } from '../../lib/research';
import { rankingBars, sensitivityBands } from '../../lib/datasets';
import { withBase } from '../../lib/paths';

const studies = await loadStudies();
const study = findStudy(studies, 'comparacion-skills-sdlc');
const adoption = findDataset(studies, 'framework-adoption-ranking');
const quality = findDataset(studies, 'framework-quality-ranking');
const sensitivity = findDataset(studies, 'framework-sensitivity');
const adoptionBars = rankingBars(adoption);
const qualityBars = rankingBars(quality);
const bands = sensitivityBands(sensitivity);
---

<BaseLayout
	title="Qué framework agéntico adoptar"
	description="Historia de decisión sobre OpenSpec, GitHub Spec Kit, Superpowers y Open GSD bajo dos prioridades de negocio."
>
	<StoryHero
		eyebrow="Historia 3 · Metodologías"
		title="El ganador cambia cuando cambia la pregunta de negocio."
		description="Adopción progresiva y piso de calidad son lentes distintas aplicadas a la misma evidencia documental."
	>
		<ExecutiveSummary>
			<p>
				<strong>OpenSpec</strong> lidera cuando prima la adopción progresiva;
				<strong>Open GSD</strong> lidera cuando control, precisión y efectividad
				prescriptiva son el objetivo principal.
			</p>
		</ExecutiveSummary>
		<div class="hero-caveat">
			<Caveat>
				<p>Las scorecards son ordinales y documentales. No miden porcentajes de productividad, calidad o velocidad.</p>
			</Caveat>
		</div>
	</StoryHero>

	<section class="story-section">
		<div class="shell">
			<header>
				<p class="eyebrow">Lente 1</p>
				<h2>Adopción progresiva y liderada por humanos</h2>
			</header>
			<div class="chart-grid">
				<BarChart
					data={adoptionBars}
					title="Ranking adopción-first"
					description="OpenSpec lidera cuando la adopción concentra el 65% del peso."
					client:visible
				/>
				<DataTable dataset={adoption} caption="Ranking de frameworks con lente adopción-first" />
			</div>
		</div>
	</section>

	<section class="story-section">
		<div class="shell">
			<header>
				<p class="eyebrow">Lente 2</p>
				<h2>Piso de calidad y proceso prescriptivo</h2>
			</header>
			<div class="chart-grid">
				<BarChart
					data={qualityBars}
					title="Ranking de piso de calidad"
					description="Open GSD lidera bajo control, precisión, organización y efectividad."
					client:visible
				/>
				<DataTable dataset={quality} caption="Ranking de frameworks con lente de piso de calidad" />
			</div>
		</div>
	</section>

	<section class="story-section">
		<div class="shell">
			<header>
				<p class="eyebrow">Sensibilidad</p>
				<h2>El punto de equilibrio está cerca del 38% de peso de adopción.</h2>
				<p>El explorador usa exclusivamente los rangos aproximados declarados por el estudio.</p>
			</header>
			<SensitivityExplorer bands={bands} client:load />
			<details>
				<summary>Consultar rangos canónicos</summary>
				<DataTable dataset={sensitivity} caption="Rangos de liderazgo según peso agregado de adopción" />
			</details>
		</div>
	</section>

	<section class="story-section">
		<div class="shell evidence-grid">
			<div>
				<p class="eyebrow">Recomendación</p>
				<h2>Elige la lente antes de elegir la herramienta.</h2>
				<p class="lede">
					OpenSpec necesita gobernanza externa determinista; Open GSD ofrece
					más proceso y también más ceremonia y superficie operativa.
				</p>
				<a class="button-link" href={withBase(`/investigaciones/${study.metadata.slug}/`)}>Leer estudio completo</a>
				<a class="button-link button-link--secondary" href={withBase('/metodologia/')}>Revisar metodología</a>
			</div>
			<EvidencePanel metadata={study.metadata} />
		</div>
	</section>
</BaseLayout>

<style>
	.hero-caveat {
		max-width: 50rem;
		margin-top: var(--space-4);
	}

	details {
		margin-top: var(--space-5);
	}

	summary {
		cursor: pointer;
		font-weight: 800;
	}

	.evidence-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--space-6);
		align-items: start;
	}

	@media (max-width: 750px) {
		.evidence-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
