---
import { ArrowRight, CircleCheck, Info, TriangleAlert } from '@lucide/astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import Badge from '../components/Badge.astro';
import ExecutiveSummary from '../components/ExecutiveSummary.astro';
import Caveat from '../components/Caveat.astro';
---

<BaseLayout
	title="Sistema de diseño"
	description="Fundamentos, componentes y codificaciones visuales del observatorio editorial AI-SDLC."
>
	<header class="shell section">
		<p class="eyebrow">Sistema de diseño</p>
		<h1 class="display">Claridad editorial con datos como protagonista.</h1>
		<p class="lede">Fundamentos y patrones compartidos antes de las composiciones de producto.</p>
	</header>

	<div class="shell showcase">
		<section aria-labelledby="tipografia">
			<h2 id="tipografia">Tipografía</h2>
			<p>
				JetBrains Mono Variable define todos los roles editoriales. Las variantes
				normal e itálica se sirven localmente con pesos de 100 a 800.
			</p>
			<div class="type-specimens">
				<p class="type-sample" data-font-sample="normal">
					<span>Regular 400</span>
					Claridad antes que espectáculo.
				</p>
				<p class="type-sample type-sample--italic" data-font-sample="italic">
					<span>Italic 400</span>
					Evidencia trazable, decisiones explícitas.
				</p>
				<p class="type-sample type-sample--bold" data-font-sample="bold">
					<span>Bold 800</span>
					AI-SDLC: observar, comparar, decidir.
				</p>
			</div>
		</section>

		<section>
			<h2>Color semántico</h2>
			<div class="swatches">
				<div class="swatch swatch--brand">Decisión / marca</div>
				<div class="swatch swatch--accent">Énfasis</div>
				<div class="swatch swatch--warning">Advertencia</div>
				<div class="swatch swatch--info">Información</div>
			</div>
		</section>

		<section>
			<h2>Estados y evidencia</h2>
			<div class="meta-row">
				<Badge tone="success">Vigente</Badge>
				<Badge tone="warning">Revalidación pendiente</Badge>
				<Badge tone="info">Evidencia mixta</Badge>
				<Badge>Metodologías</Badge>
			</div>
		</section>

		<section aria-labelledby="iconografia">
			<h2 id="iconografia">Iconografía SVG</h2>
			<p>
				Lucide aporta un conjunto restringido de iconos inline. Heredan el color
				del texto, comparten grosor de trazo y siempre refuerzan una etiqueta
				visible en lugar de sustituirla.
			</p>
			<div class="icon-specimens">
				<div class="icon-sample">
					<CircleCheck class="icon icon--lg" aria-hidden="true" focusable="false" />
					<span>Estado positivo</span>
				</div>
				<div class="icon-sample">
					<TriangleAlert class="icon icon--lg" aria-hidden="true" focusable="false" />
					<span>Advertencia</span>
				</div>
				<div class="icon-sample">
					<Info class="icon icon--lg" aria-hidden="true" focusable="false" />
					<span>Información</span>
				</div>
				<div class="icon-sample">
					<ArrowRight class="icon icon--lg" aria-hidden="true" focusable="false" />
					<span>Acción o avance</span>
				</div>
			</div>
			<ul class="icon-rules">
				<li>Tamaños: 14, 16 y 24 píxeles; trazo compartido de 2.</li>
				<li>Color: <code>currentColor</code>, sin codificación exclusivamente cromática.</li>
				<li>Accesibilidad: SVG oculto cuando existe texto equivalente adyacente.</li>
				<li>Un control compuesto solo por un icono requiere nombre accesible explícito.</li>
			</ul>
		</section>

		<section>
			<h2>Jerarquía editorial</h2>
			<ExecutiveSummary>
				<p>La conclusión ejecutiva debe entenderse antes de cualquier interacción.</p>
			</ExecutiveSummary>
			<Caveat>
				<p>El caveat material se presenta cerca de la afirmación que limita.</p>
			</Caveat>
		</section>

		<section>
			<h2>Tabla accesible</h2>
			<div class="table-scroll" tabindex="0" role="region" aria-label="Ejemplo de codificación">
				<table class="data-table">
					<thead><tr><th>Señal</th><th>Representación</th><th>Alternativa no cromática</th></tr></thead>
					<tbody>
						<tr><td>Vigencia</td><td>Verde / ámbar</td><td>Texto de estado</td></tr>
						<tr><td>Confianza</td><td>Badge informativo</td><td>Etiqueta explícita</td></tr>
						<tr><td>Selección</td><td>Contorno y contraste</td><td>Foco y atributo seleccionado</td></tr>
					</tbody>
				</table>
			</div>
		</section>
	</div>
</BaseLayout>

<style>
	.showcase {
		display: grid;
		gap: var(--space-7);
	}

	h2 {
		font-family: var(--font-serif);
		font-size: var(--step-3);
		font-weight: 500;
	}

	.type-specimens {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: var(--space-3);
	}

	.type-sample {
		display: grid;
		gap: var(--space-3);
		min-width: 0;
		margin: 0;
		padding: var(--space-5);
		border: 1px solid var(--color-line);
		border-radius: var(--radius-lg);
		background: var(--color-surface);
		font-size: var(--step-1);
		overflow-wrap: anywhere;
	}

	.type-sample span {
		color: var(--color-brand);
		font-size: var(--step--1);
		font-style: normal;
		font-weight: 800;
		text-transform: uppercase;
	}

	.type-sample--italic {
		font-style: italic;
	}

	.type-sample--bold {
		font-weight: 800;
	}

	.swatches {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: var(--space-3);
	}

	.icon-specimens {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: var(--space-3);
	}

	.icon-sample {
		display: flex;
		min-width: 0;
		align-items: center;
		gap: var(--space-3);
		padding: var(--space-4);
		border: 1px solid var(--color-line);
		border-radius: var(--radius-md);
		background: var(--color-surface);
		color: var(--color-brand-strong);
		font-weight: 800;
	}

	.icon-rules {
		max-width: var(--measure);
	}

	.swatch {
		display: grid;
		min-height: 8rem;
		place-items: end start;
		padding: var(--space-4);
		border-radius: var(--radius-lg);
		color: white;
		font-weight: 800;
	}

	.swatch--brand { background: var(--color-brand); }
	.swatch--accent { background: var(--color-accent); }
	.swatch--warning { background: var(--color-warning); }
	.swatch--info { background: var(--color-info); }

	section > :global(.summary),
	section > :global(.caveat) {
		margin-bottom: var(--space-4);
	}

	@media (max-width: 700px) {
		.type-specimens {
			grid-template-columns: 1fr;
		}

		.swatches {
			grid-template-columns: 1fr 1fr;
		}

		.icon-specimens {
			grid-template-columns: 1fr 1fr;
		}
	}
</style>
