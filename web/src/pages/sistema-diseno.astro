---
import { ArrowRight, CircleCheck, Info, TriangleAlert } from '@lucide/astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import Badge from '../components/Badge.astro';
import ExecutiveSummary from '../components/ExecutiveSummary.astro';
import Caveat from '../components/Caveat.astro';
import DataTable from '../components/DataTable.astro';
import { secondaryNavigationDestinations } from '../lib/navigation';
import type { ResearchDataset } from '../lib/types';

const tableExample: ResearchDataset = {
	id: 'design-system-compatibility',
	schema: 'compatibility-matrix',
	unit: 'categorical',
	sourceFile: 'sistema-diseno.astro',
	headers: [
		'Clave de agente',
		'Agente',
		'Clave de componente',
		'Componente',
		'Estado',
		'Mecanismo',
		'Nota',
		'Fuente',
		'Verificado el',
	],
	rows: [
		{
			'Clave de agente': '`copilot-cli`',
			Agente: 'Copilot CLI',
			'Clave de componente': '`openspec`',
			Componente: 'OpenSpec',
			Estado: 'nativa',
			Mecanismo: 'Skills del repositorio',
			Nota: 'La relación se conserva como evidencia verificable.',
			Fuente: 'Documentación oficial',
			'Verificado el': '2026-07-22',
		},
		{
			'Clave de agente': '`opencode`',
			Agente: 'OpenCode',
			'Clave de componente': '`openspec`',
			Componente: 'OpenSpec',
			Estado: 'nativa',
			Mecanismo: 'Skills y comandos',
			Nota: 'La columna identificadora mantiene el contexto al desplazarse.',
			Fuente: 'Documentación oficial',
			'Verificado el': '2026-07-22',
		},
	],
};
---

<BaseLayout
	title="Sistema de diseño"
	description="Fundamentos, componentes y codificaciones visuales del observatorio editorial AI-SDLC."
	breadcrumbs={[
		{ label: 'Portada', path: '/' },
		{ label: secondaryNavigationDestinations.designSystem.label },
	]}
>
	<header class="shell section">
		<p class="eyebrow">Sistema de diseño</p>
		<h1 class="display">Claridad editorial con datos como protagonista.</h1>
		<p class="lede">Fundamentos y patrones compartidos antes de las composiciones de producto.</p>
	</header>

	<div class="shell showcase">
		<section aria-labelledby="tipografia">
			<h2 id="tipografia">Tipografía</h2>
			<p>
				Atkinson Hyperlegible Next sostiene interfaz y lectura prolongada.
				JetBrains Mono conserva la precisión técnica de datos, metadatos,
				comandos y etiquetas. Ambas familias se sirven localmente.
			</p>
			<div class="type-role">
				<header>
					<p class="type-role__token"><code>--font-body / --font-ui</code></p>
					<h3>Atkinson Hyperlegible Next</h3>
					<p>Para entender instrucciones, conclusiones y prosa con rapidez.</p>
				</header>
				<div class="type-specimens">
					<p class="type-sample" data-font-family="atkinson" data-font-sample="normal">
						<span>Lectura · Regular 400</span>
						Claridad antes que espectáculo.
					</p>
					<p class="type-sample type-sample--italic" data-font-family="atkinson" data-font-sample="italic">
						<span>Énfasis · Italic 400</span>
						Evidencia trazable, decisiones explícitas.
					</p>
					<p class="type-sample type-sample--bold" data-font-family="atkinson" data-font-sample="bold">
						<span>Interfaz · Bold 800</span>
						Observar, comparar y decidir.
					</p>
				</div>
			</div>
			<div class="type-role type-role--data">
				<header>
					<p class="type-role__token"><code>--font-data</code></p>
					<h3>JetBrains Mono</h3>
					<p>Para conservar alineación y reconocer cifras, estados y comandos.</p>
				</header>
				<div class="type-specimens">
					<p class="type-sample" data-font-family="jetbrains" data-font-sample="normal">
						<span>Dato · Regular 400</span>
						Puntaje: 66,1 / 100
					</p>
					<p class="type-sample type-sample--italic" data-font-family="jetbrains" data-font-sample="italic">
						<span>Nota · Italic 400</span>
						Evidencia mixta · corte 2026-07-22
					</p>
					<p class="type-sample type-sample--bold" data-font-family="jetbrains" data-font-sample="bold">
						<span>Estado · Bold 800</span>
						REVALIDACIÓN PENDIENTE
					</p>
				</div>
			</div>
		</section>

		<section aria-labelledby="paleta-tinta-costera">
			<h2 id="paleta-tinta-costera">Paleta Tinta Costera</h2>
			<p>
				Los índigos aportan profundidad, el teal concentra los acentos y los
				tintes claros mantienen una composición abierta y aireada.
			</p>
			<div class="swatches">
				<div class="swatch swatch--deep" data-palette-color="#12233F">
					<div class="swatch__label">
						<strong>Índigo profundo</strong>
						<code>#12233F</code>
						<span>Encabezados, navegación y superficies oscuras</span>
					</div>
				</div>
				<div class="swatch swatch--indigo" data-palette-color="#243B77">
					<div class="swatch__label">
						<strong>Índigo interactivo</strong>
						<code>#243B77</code>
						<span>Enlaces, botones y estados positivos</span>
					</div>
				</div>
				<div class="swatch swatch--teal" data-palette-color="#2F7EA8">
					<div class="swatch__label">
						<strong>Teal de acento</strong>
						<code>#2F7EA8</code>
						<span>Iconos, gráficos, foco y acentos</span>
					</div>
				</div>
				<div class="swatch swatch--aqua" data-palette-color="#CBEAF2">
					<div class="swatch__label">
						<strong>Aqua pálido</strong>
						<code>#CBEAF2</code>
						<span>Fondos destacados y separación de secciones</span>
					</div>
				</div>
				<div class="swatch swatch--paper" data-palette-color="#F7FBFF">
					<div class="swatch__label">
						<strong>Blanco costero</strong>
						<code>#F7FBFF</code>
						<span>Fondo general y espacio abierto</span>
					</div>
				</div>
			</div>
			<p class="palette-note">
				El ámbar se conserva exclusivamente para advertencias; el teal no se usa
				como texto normal sobre fondos claros. Los componentes consumen roles
				semánticos, no estos valores primitivos directamente.
			</p>
		</section>

		<section aria-labelledby="superficies">
			<h2 id="superficies">Jerarquía de superficies</h2>
			<p>
				Una superficie estática organiza información sin anunciar una acción.
				Solo las superficies accionables responden al puntero, foco y activación.
			</p>
			<div class="surface-specimens">
				<article class="surface surface-sample" data-surface="static">
					<p class="surface-sample__label">Panel estático</p>
					<h3>Contexto de lectura</h3>
					<p>Usa borde y fondo para agrupar contenido, sin elevación ni respuesta hover.</p>
				</article>
				<a
					class="surface surface--interactive surface-sample"
					data-surface="interactive"
					href="#estados-interaccion"
				>
					<p class="surface-sample__label">Superficie interactiva</p>
					<h3>Consultar estados</h3>
					<p>Expone destino, foco visible y respuesta coherente al activarse.</p>
				</a>
				<article class="surface surface--selected surface-sample" data-surface="selected">
					<p class="surface-sample__label">Selección</p>
					<h3>Opción activa</h3>
					<p>El texto y el contorno complementan el cambio de color.</p>
				</article>
				<article class="surface surface--warning surface-sample" data-surface="warning">
					<p class="surface-sample__label">Advertencia</p>
					<h3>Revalidación necesaria</h3>
					<p>El estado combina lenguaje explícito, borde y superficie semántica.</p>
				</article>
			</div>
		</section>

		<section id="estados-interaccion" aria-labelledby="estados">
			<h2 id="estados">Estados de interacción y evidencia</h2>
			<p>
				Hover refuerza una acción; el foco visible la hace navegable con teclado;
				disabled comunica indisponibilidad sin simular una respuesta.
			</p>
			<div class="interaction-specimens">
				<a class="button-link" href="#jerarquia-editorial">Acción disponible</a>
				<button type="button" disabled>Acción no disponible</button>
			</div>
			<div class="meta-row">
				<Badge tone="success">Vigente</Badge>
				<Badge tone="warning">Revalidación pendiente</Badge>
				<Badge tone="info">Evidencia mixta</Badge>
				<Badge>Metodologías</Badge>
			</div>
		</section>

		<section aria-labelledby="iconografia">
			<h2 id="iconografia">Iconografía SVG</h2>
			<p>
				Lucide aporta un conjunto restringido de iconos inline. Heredan el color
				del texto, comparten grosor de trazo y siempre refuerzan una etiqueta
				visible en lugar de sustituirla.
			</p>
			<div class="icon-specimens">
				<div class="icon-sample">
					<CircleCheck class="icon icon--lg" aria-hidden="true" focusable="false" />
					<span>Estado positivo</span>
				</div>
				<div class="icon-sample">
					<TriangleAlert class="icon icon--lg" aria-hidden="true" focusable="false" />
					<span>Advertencia</span>
				</div>
				<div class="icon-sample">
					<Info class="icon icon--lg" aria-hidden="true" focusable="false" />
					<span>Información</span>
				</div>
				<div class="icon-sample">
					<ArrowRight class="icon icon--lg" aria-hidden="true" focusable="false" />
					<span>Acción o avance</span>
				</div>
			</div>
			<ul class="icon-rules">
				<li>Tamaños: 14, 16 y 24 píxeles; trazo compartido de 2.</li>
				<li>Color: <code>currentColor</code>, sin codificación exclusivamente cromática.</li>
				<li>Accesibilidad: SVG oculto cuando existe texto equivalente adyacente.</li>
				<li>Un control compuesto solo por un icono requiere nombre accesible explícito.</li>
			</ul>
		</section>

		<section id="jerarquia-editorial">
			<h2>Jerarquía editorial</h2>
			<ExecutiveSummary>
				<p>La conclusión ejecutiva debe entenderse antes de cualquier interacción.</p>
			</ExecutiveSummary>
			<Caveat>
				<p>El caveat material se presenta cerca de la afirmación que limita.</p>
			</Caveat>
		</section>

		<section>
			<h2>Tabla accesible</h2>
			<p>
				El marco en L conserva los ejes de consulta; el selector cambia la
				presentación sin retirar evidencia del HTML canónico.
			</p>
			<DataTable
				dataset={tableExample}
				caption="Ejemplo de compatibilidad verificable"
				initiallyHiddenColumns={['Clave de agente', 'Clave de componente']}
			/>
		</section>
	</div>
</BaseLayout>

<style>
	.showcase {
		display: grid;
		gap: var(--space-7);
	}

	h2 {
		font-family: var(--font-ui);
		font-size: var(--step-3);
		font-weight: 650;
	}

	.type-role {
		display: grid;
		gap: var(--space-4);
		margin-top: var(--space-5);
		padding-top: var(--space-5);
		border-top: 1px solid var(--color-line);
	}

	.type-role header {
		max-width: var(--measure);
	}

	.type-role h3 {
		margin-block: var(--space-1);
		font-size: var(--step-2);
	}

	.type-role__token {
		margin: 0;
		color: var(--color-action);
		font-family: var(--font-data);
		font-size: var(--step--1);
		font-weight: 800;
	}

	.type-specimens {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: var(--space-3);
	}

	.type-sample {
		display: grid;
		gap: var(--space-3);
		min-width: 0;
		margin: 0;
		padding: var(--space-5);
		border: 1px solid var(--color-line);
		border-radius: var(--radius-lg);
		background: var(--color-surface-static);
		font-family: var(--font-body);
		font-size: var(--step-1);
		overflow-wrap: anywhere;
	}

	.type-sample span {
		color: var(--color-action);
		font-family: var(--font-data);
		font-size: var(--step--1);
		font-style: normal;
		font-weight: 800;
		text-transform: uppercase;
	}

	.type-sample--italic {
		font-style: italic;
	}

	.type-sample--bold {
		font-weight: 800;
	}

	.type-role--data .type-sample {
		font-family: var(--font-data);
	}

	.surface-specimens {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: var(--space-3);
	}

	.surface-sample {
		display: block;
		min-width: 0;
		padding: var(--space-4);
		color: inherit;
		text-decoration: none;
	}

	.surface-sample h3 {
		margin-block: var(--space-1);
	}

	.surface-sample p {
		margin-bottom: 0;
	}

	.surface-sample__label {
		color: var(--color-action);
		font-family: var(--font-data);
		font-size: var(--step--1);
		font-weight: 800;
		text-transform: uppercase;
	}

	.surface--warning .surface-sample__label {
		color: var(--color-status-warning);
	}

	.interaction-specimens {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-3);
		margin-block: var(--space-4);
	}

	.interaction-specimens button {
		padding: 0.7rem 1rem;
		border: 1px solid var(--color-line-strong);
		border-radius: 999px;
		background: var(--color-surface-control);
		color: var(--color-text);
		font-weight: 750;
	}

	.swatches {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(10rem, 1fr));
		gap: var(--space-3);
	}

	.icon-specimens {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: var(--space-3);
	}

	.icon-sample {
		display: flex;
		min-width: 0;
		align-items: center;
		gap: var(--space-3);
		padding: var(--space-4);
		border: 1px solid var(--color-line);
		border-radius: var(--radius-md);
		background: var(--color-surface-static);
		color: var(--color-action-hover);
		font-weight: 800;
	}

	.icon-rules {
		max-width: var(--measure);
	}

	.swatch {
		display: flex;
		flex-direction: column;
		min-height: 10rem;
		justify-content: flex-end;
		align-items: flex-start;
		border-radius: var(--radius-lg);
		overflow: hidden;
	}

	.swatch__label {
		display: grid;
		width: 100%;
		gap: var(--space-1);
		margin-top: auto;
		padding: var(--space-3) var(--space-4);
		background: var(--color-surface-static);
		color: var(--color-text);
	}

	.swatch__label strong {
		font-weight: 800;
	}

	.swatch__label code {
		color: inherit;
		font-family: var(--font-data);
		font-size: var(--step--1);
	}

	.swatch__label span {
		font-size: 0.75rem;
		line-height: 1.4;
	}

	.swatch--deep { background: var(--color-coast-deep); }
	.swatch--indigo { background: var(--color-coast-indigo); }
	.swatch--teal { background: var(--color-coast-teal); }
	.swatch--aqua {
		background: var(--color-coast-aqua);
	}
	.swatch--paper {
		border: 1px solid var(--color-line-strong);
		background: var(--color-coast-paper);
	}

	.palette-note {
		max-width: var(--measure);
		color: var(--color-text-muted);
	}

	section > :global(.summary),
	section > :global(.caveat) {
		margin-bottom: var(--space-4);
	}

	@media (max-width: 700px) {
		.type-specimens {
			grid-template-columns: 1fr;
		}

		.surface-specimens {
			grid-template-columns: 1fr;
		}

		.icon-specimens {
			grid-template-columns: 1fr 1fr;
		}
	}
</style>
