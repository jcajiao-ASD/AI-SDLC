<script>
	function tableCells(frame: HTMLElement, columnIndex: string): HTMLElement[] {
		return Array.from(
			frame.querySelectorAll<HTMLElement>(
				`.data-table [data-column-index="${columnIndex}"]`,
			),
		);
	}

	function initializeTable(frame: HTMLElement): void {
		if (frame.dataset.tableReady === 'true') return;
		const scroll = frame.querySelector<HTMLElement>('[data-table-scroll]');
		const table = frame.querySelector<HTMLTableElement>('.data-table');
		if (!scroll || !table) return;

		const toggles = Array.from(
			frame.querySelectorAll<HTMLInputElement>('[data-table-column-toggle]'),
		);
		const count = frame.querySelector<HTMLElement>('[data-table-column-count]');
		const updateCount = () => {
			if (!count) return;
			const visible = toggles.filter((toggle) => toggle.checked).length;
			count.textContent = `${visible} de ${toggles.length}`;
		};
		const setColumnHidden = (columnIndex: string, hidden: boolean) => {
			for (const cell of tableCells(frame, columnIndex)) cell.hidden = hidden;
		};

		for (const toggle of toggles) {
			if (!toggle.checked) setColumnHidden(toggle.dataset.columnIndex ?? '', true);
			toggle.addEventListener('change', () => {
				setColumnHidden(toggle.dataset.columnIndex ?? '', !toggle.checked);
				updateCount();
			});
		}
		updateCount();
		frame.dataset.tableReady = 'true';

		const updateLayout = () => {
			const overflows = scroll.scrollWidth > scroll.clientWidth + 1;
			const labelId = scroll.dataset.tableLabelId;
			if (overflows) {
				scroll.setAttribute('role', 'region');
				scroll.tabIndex = 0;
				if (labelId) scroll.setAttribute('aria-labelledby', labelId);
			} else if (frame.dataset.tableWide !== 'true') {
				scroll.removeAttribute('role');
				scroll.removeAttribute('tabindex');
				scroll.removeAttribute('aria-labelledby');
			}

			const rowHeader = table.querySelector<HTMLElement>('tbody th[scope="row"]');
			const remainingWidth = rowHeader
				? scroll.clientWidth - rowHeader.getBoundingClientRect().width
				: 0;
			const minimumRemaining = 18 * Number.parseFloat(
				getComputedStyle(document.documentElement).fontSize,
			);
			const canStick = Boolean(
				overflows &&
				rowHeader &&
				rowHeader.getBoundingClientRect().width <= scroll.clientWidth * 0.42 &&
				remainingWidth >= minimumRemaining,
			);
			frame.classList.toggle('table-frame--sticky-column', canStick);
		};

		updateLayout();
		new ResizeObserver(updateLayout).observe(scroll);
	}

	interface SelectDetail {
		group: string;
		key: string | null;
	}

	const selectEventName = 'datavis:select';

	function initializeCoordination(frame: HTMLElement): void {
		const group = frame.dataset.vizGroup;
		if (!group || frame.dataset.coordinationReady === 'true') return;
		const rows = Array.from(
			frame.querySelectorAll<HTMLTableRowElement>('tbody tr[data-row-key]'),
		);
		if (rows.length === 0) return;

		const select = (key: string | null) => {
			for (const row of rows) {
				row.setAttribute('aria-selected', String(row.dataset.rowKey === key));
				row.classList.toggle('table-row--selected', row.dataset.rowKey === key);
			}
		};

		for (const row of rows) {
			const key = row.dataset.rowKey ?? null;
			row.addEventListener('click', () => {
				const next = row.getAttribute('aria-selected') === 'true' ? null : key;
				select(next);
				document.dispatchEvent(
					new CustomEvent<SelectDetail>(selectEventName, { detail: { group, key: next } }),
				);
			});
			row.addEventListener('keydown', (event) => {
				if (event.key !== 'Enter' && event.key !== ' ') return;
				event.preventDefault();
				row.click();
			});
		}

		document.addEventListener(selectEventName, (event) => {
			const detail = (event as CustomEvent<SelectDetail>).detail;
			if (!detail || detail.group !== group) return;
			select(detail.key);
		});

		frame.dataset.coordinationReady = 'true';
	}

	for (const frame of document.querySelectorAll<HTMLElement>('[data-table-frame]')) {
		initializeTable(frame);
		initializeCoordination(frame);
	}
</script>
