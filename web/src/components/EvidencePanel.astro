---
import Badge from './Badge.astro';
import { isPastRevalidation } from '../lib/research';
import type { ResearchMetadata } from '../lib/types';

interface Props {
	metadata: ResearchMetadata;
}

const { metadata } = Astro.props;
const stale = isPastRevalidation(metadata);
---

<aside class="evidence" aria-label="Ficha de evidencia">
	<div>
		<p class="evidence__label">Evidencia y vigencia</p>
		<h2>{metadata.title}</h2>
	</div>
	<div class="meta-row">
		<Badge tone={stale ? 'warning' : 'success'}>{stale ? 'Revalidación pendiente' : metadata.status}</Badge>
		<Badge tone="info">Evidencia {metadata.evidenceLevel}</Badge>
		<Badge>{metadata.category}</Badge>
	</div>
	<dl>
		<div><dt>Fecha de corte</dt><dd>{metadata.cutoffDate}</dd></div>
		<div><dt>Revalidar desde</dt><dd>{metadata.revalidateAfter}</dd></div>
		<div><dt>Tipo de decisión</dt><dd>{metadata.decisionType}</dd></div>
	</dl>
</aside>

<style>
	.evidence {
		display: grid;
		gap: var(--space-4);
		padding: var(--space-5);
		border: 1px solid var(--color-line);
		border-radius: var(--radius-lg);
		background: var(--color-surface);
	}

	.evidence__label {
		margin: 0;
		color: var(--color-brand);
		font-size: var(--step--1);
		font-weight: 900;
		text-transform: uppercase;
	}

	h2 {
		margin: var(--space-1) 0 0;
		font-size: var(--step-1);
	}

	dl {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: var(--space-4);
		margin: 0;
	}

	dt {
		color: var(--color-ink-soft);
		font-size: var(--step--1);
		font-weight: 700;
	}

	dd {
		margin: 0;
		font-weight: 750;
	}

	@media (max-width: 650px) {
		dl {
			grid-template-columns: 1fr;
		}
	}
</style>
