---
import type { ResearchDataset } from '../lib/types';
import { plainText } from '../lib/datasets';

interface Props {
	dataset: ResearchDataset;
	caption: string;
}

const { dataset, caption } = Astro.props;
---

<div class="table-scroll" tabindex="0" role="region" aria-label={caption}>
	<table class="data-table">
		<caption class="sr-only">{caption}</caption>
		<thead>
			<tr>{dataset.headers.map((header) => <th scope="col">{header}</th>)}</tr>
		</thead>
		<tbody>
			{dataset.rows.map((row) => (
				<tr>{dataset.headers.map((header) => <td>{plainText(row[header])}</td>)}</tr>
			))}
		</tbody>
	</table>
</div>
